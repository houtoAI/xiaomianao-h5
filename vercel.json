{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "public/homepage.html"
    },
    {
      "src": "/app",
      "dest": "public/index.html"
    },
    {
      "src": "/api/nav/(.*)",
      "dest": "api/nav.js"
    },
    {
      "src": "/health",
      "dest": "api/health.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/$1.js"
    },
    {
      "src": "/v1/(.*)",
      "dest": "api/chat.js"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}